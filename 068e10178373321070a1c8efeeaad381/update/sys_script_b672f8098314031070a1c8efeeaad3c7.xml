        <script><![CDATA[(function executeRule(current, previous) {

    // Get task ID - handle delete case
    var taskID = current.task.toString();
    if (!taskID) {
        // On delete, check previous record
        if (previous) {
            taskID = previous.task.toString();
        }
    }
    
    if (!taskID) return;
    
    // Sum all hours worked for this task
    var log = new GlideAggregate('x_1954179_employ_0_work_log_entry');
    log.addQuery('task', taskID);
    log.addAggregate('SUM', 'hours_worked');
    log.query();
    
    var totalHours = 0;
    if (log.next()) {
        totalHours = parseFloat(log.getAggregate('SUM', 'hours_worked')) || 0;
    }
    
    // Update the task's actual hours
    var task = new GlideRecord('x_1954179_employ_0_task');
    if (task.get(taskID)) {
        task.actual_hours = totalHours;
        task.update();
    }

})(current, previous);]]></script>
