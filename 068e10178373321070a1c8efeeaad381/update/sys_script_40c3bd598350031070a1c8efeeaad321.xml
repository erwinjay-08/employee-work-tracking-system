        <script><![CDATA[(function executeRule(current, previous) {
    if (current.employee.nil()) return;
    
    var emp = new GlideRecord('x_1954179_employ_0_employee');
    if (emp.get(current.employee)) {
        var requested = parseFloat(current.total_days.toString()) || 0;
        var available = parseFloat(emp.leave_balance.toString()) || 0;
        
        if (requested > available) {
            gs.addErrorMessage('Insufficient leave balance. Available: ' 
                + available + ' days. Requested: ' + requested + ' days.');
            current.setAbortAction(true);
        }
    }
})(current, previous);]]></script>
