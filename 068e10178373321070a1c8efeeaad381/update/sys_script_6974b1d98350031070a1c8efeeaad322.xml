        <script><![CDATA[(function executeRule(current, previous) {
    if (current.employee.nil()) return;
    
    var emp = new GlideRecord('x_1954179_employ_0_employee');
    if (emp.get(current.employee)) {
        var days = parseFloat(current.total_days.toString()) || 0;
        var balance = parseFloat(emp.leave_balance.toString()) || 0;
        emp.leave_balance = balance - days;
        emp.update();

        gs.addInfoMessage('Leave balance updated. New balance: ' 
            + (balance - days) + ' days.');
    }
})(current, previous);]]></script>
