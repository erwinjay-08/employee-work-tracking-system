        <script><![CDATA[function submitTimesheet() {
  if (!g_form.getValue('employee')) {
    alert('Please select an Employee before submitting.');
    return;
  }
  if (!g_form.getValue('week_start_date')) {
    alert('Please enter the Week Start Date before submitting.');
    return;
  }
  g_form.setValue('status', 'submitted');
  g_form.save();
}

function onLoad() {
  if (g_form.getValue('status') !== 'draft') {
    g_ui_actions.hide('submit_timesheet');
  }
}]]></script>
