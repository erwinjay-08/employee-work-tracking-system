        <name>Submit Timesheet</name>
        <onclick>submitTimesheet()</onclick>
        <order>100</order>
        <script><![CDATA[(function executeRule(current, previous) {

    // Validate employee is selected
    if (current.employee.nil()) {
        gs.addErrorMessage('Please select an Employee before submitting.');
        current.setAbortAction(true);
        return;
    }

    // Validate week start date
    if (current.week_start_date.nil()) {
        gs.addErrorMessage('Please enter the Week Start Date before submitting.');
        current.setAbortAction(true);
        return;
    }

    // Submit the timesheet
    current.status = 'submitted';
    current.submitted_by = gs.getUserID();
    current.update();
    action.setRedirectURL(current);

})(current, previous);]]></script>
