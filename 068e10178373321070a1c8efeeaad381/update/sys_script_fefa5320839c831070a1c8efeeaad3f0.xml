        <script><![CDATA[(function executeRule(current, previous) {

    if (current.start_date.nil() || current.end_date.nil()) return;
    
    var start = new GlideDateTime();
    start.setDisplayValue(current.start_date.getDisplayValue());
    
    var end = new GlideDateTime();
    end.setDisplayValue(current.end_date.getDisplayValue());
    
    var days = 0;
    var cur = new GlideDateTime(start);
    
    while (cur.compareTo(end) <= 0) {
        var dow = cur.getDayOfWeek(); // 1=Sun, 7=Sat
        if (dow !== 1 && dow !== 7) {
            days++;
        }
        cur.addDaysUTC(1);
    }
    
    current.total_days = days;

})(current, previous);]]></script>
