        <script><![CDATA[(function executeRule(current, previous) {

    var days = [
        'monday_hours',
        'tuesday_hours', 
        'wednesday_hours',
        'thursday_hours',
        'friday_hours',
        'saturday_hours',
        'sunday_hours'
    ];
    
    var total = 0;
    days.forEach(function(d) {
        var val = parseFloat(current[d].toString()) || 0;
        total += val;
    });
    
    var standard = 40;
    current.total_regular_hours = Math.min(total, standard);
    current.total_overtime = Math.max(0, total - standard);

})(current, previous);]]></script>
